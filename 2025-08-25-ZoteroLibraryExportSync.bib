  author = {Mikus, Jenna and Rieger, Janice},
  editor = {Verma, Ira},
  date = {2021-06-04},
  series = {Studies in {{Health Technology}} and {{Informatics}}},
  volume = {282},
  publisher = {IOS Press},
  doi = {10.3233/SHTI210381},
  url = {https://ebooks.iospress.nl/doi/10.3233/SHTI210381},
  urldate = {2024-05-04},
  abstract = {Industry and academic perspectives have become more focused on designing for Diversity and Inclusion (D\&I) over the past few years, both in general and particularly within the built environment. This renewed interest appears to have stemmed from a basis of respect-based ‘due diligence’ in 2018 to one of necessity in 2020, when the COVID-19 pandemic brought areas of difference into focus and exacerbated them, making it harder for people to live their everyday lives. In this paper, the authors seek to bridge the divide between academia and industry on the subject of Inclusive Design (ID) through their use of a combination of an academic and grey literature review as well as empirical research conducted with scholars and practitioners. These multiple methods focus less on the academic perspectives and more on how the industry has responded to the research and market demand. It clarifies nuanced differences among ID-related terms, provides best practice examples for wellness in the built environment, and identifies governing body guidelines (i.e., principles, protocols, policies) that have been enacted for ethical and business differentiating purposes.},
  isbn = {978-1-64368-190-0 978-1-64368-191-7},
  keywords = {ADA,architecture,D.Min.,inclusion,inclusive design,NTS,process_to_obsidian,Universal Design},
  file = {/Users/jeremyengland/Zotero/storage/B8WI8U74/IVerma_2021_InclusiveDesignAsAMar_UniversalDesign2021Fr.pdf}
}

