@thesis{hulshofJesusDisabledInclusive2017,
  type = {Ed.D.},
  title = {Jesus and the {{Disabled}}: {{Inclusive Leadership}} and the {{Disability Effective Pastor}}},
  author = {Hulshof, Chris},
  namea = {Lawson, Gregory and Porowski, James},
  nameatype = {collaborator},
  date = {2017},
  journaltitle = {ProQuest Dissertations and Theses},
  institution = {Southeastern Baptist Theological Seminary},
  location = {United States -- North Carolina},
  url = {http://proxy.libraries.smu.edu/login?url=https://www.proquest.com/dissertations-theses/jesus-disabled-inclusive-leadership-disability/docview/1886416771/se-2?accountid=6667},
  abstract = {The Scripture, from beginning to end, addresses God’s desire that those who are disabled be included in the community of faith. This inclusion is most evident in the ministry of Jesus. More specifically, it can be seen in the miraculous healing stories of Jesus Christ. Examining these stories provides a model for disability ministry that can be implemented in church ministry.    Chapter one of this research identifies the rationale for this study and notes the four foundational questions of this research. First, what current literature exists that provides instructive material for inclusionary and disability effective church leadership? Second, how is Jesus’s interaction with the disabled in the Synoptic Gospels an example of inclusive leadership? Third, how is Jesus’s interaction with the disabled in the Gospel of John an example of inclusive leadership? Finally, what implications does Jesus’s example of inclusive leadership have for disability effective church leadership?    Chapter two presents a brief overview of current literature related to disability studies in the areas of theology, church ministry, and leadership. This chapter also recognizes the critical characteristics of inclusive leadership as the framework for evaluating Jesus’s ministry to the disabled.    Chapter three examines the healing miracles of Jesus common to all three of the Synoptic Gospels. Similarly, chapter four focuses on two specific healing miracles recorded in the Gospel of John. Using the critical characteristics of inclusive leadership, the research seeks to understand if Jesus’s interaction with the disabled demonstrates that he was an inclusive leader.    Chapter five concludes this research by examining past and present models of disability ministry. This chapter also presents four models of church ministry. These models are designed to move a congregation to greater levels of disability inclusion. Key Words: Disability, Inclusive Leadership, Church Ministry, Jesus’s Miracles},
  isbn = {978-1-369-69668-4},
  langid = {english},
  pagetotal = {252},
  keywords = {0318:Religion,0319:Clergy,0469:Theology,Church ministry,Clergy,Clerical studies,Disability,Inclusion,Inclusive leadership,Jesus' miracles,Pastoral leadership,Philosophy religion and theology,Religion,Theology},
  annotation = {10266384},
  file = {/Users/jeremyengland/Zotero/storage/WTADN3WX/Hulshof - 2017 - Jesus and the Disabled Inclusive Leadership and the Disability Effective Pastor.pdf}
}

