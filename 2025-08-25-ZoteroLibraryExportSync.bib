@incollection{mikusInclusiveDesignMarket2021,
  title = {Inclusive {{Design}} as a {{Market Differentiator}}: {{An Industry}} and {{Academic Perspective}} on {{Diversity-Driven Initiatives}} in {{Built Environment Design Across North America}}, {{Europe}}, the {{UK}}, and {{Australia}}},
