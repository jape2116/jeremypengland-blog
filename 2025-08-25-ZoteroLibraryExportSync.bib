  title = {Why Ordination? {{A}} Study of Factors Contributing to People under Age 30 Seeking Ordination in a Post-{{Christendom}} Culture},
  author = {Ethridge, Glenn Leland},
  namea = {Guder, Darrell L. and Mikoski, Gordon S.},
  nameatype = {collaborator},
  date = {2011},
  journaltitle = {ProQuest Dissertations and Theses},
  institution = {Princeton Theological Seminary},
  location = {United States -- New Jersey},
  url = {http://proxy.libraries.smu.edu/login?url=https://www.proquest.com/dissertations-theses/why-ordination-study-factors-contributing-people/docview/908650346/se-2?accountid=6667},
  abstract = {Since at least 1970 theologians have pointed to the death of Christendom in the United States. Douglas John Hall and others have pointed to the church's loss of influence and prestige within North American culture. One measureable manifestation of this trend is a decrease in the number of young people being ordained in the United Methodist Church. The United Methodist Church and other mainline Protestant denominations seek to reverse the trend but there is little data available on what contributes to the youth of the new millennium pursuing ordination. This project examines the influences young people (under age 30) identify as significant in their decision to enter ordained ministry in the North Georgia Conference of the United Methodist Church. The research is based on in-depth interviews with persons ordained in the North Georgia Conference between 2002 and 2008. In compiling the data from the qualitative study I sought to identify common experiences, events, personal relationships and institutional relationships.    My research showed at least three major factors that influence young adults decisions to enter ordained ministry: (1) the opportunity to develop competency in skills associated with ordained ministry, (2) strong relationships with lay and clergy mentors, and (3) high levels of participation in traditional activities of church including worship, Sunday school, Vacation Bible school, youth group, and retreats. Faculty advisors for this project were Dr. Darrell L. Guder and Dr. Gordon S. Mikoski.},
  isbn = {978-1-267-04094-7},
  langid = {english},
  pagetotal = {120},
  keywords = {0319:Clergy,0469:Theology,0525:Educational psychology,Career counseling,Clergy,Clerical studies,Education,Educational psychology,Ordination,Philosophy religion and theology,Post-Christendom,Theology,Vocational discernment},
  annotation = {3485953},
  file = {/Users/jeremyengland/Zotero/storage/UELTHXTC/Ethridge - 2011 - Why ordination A study of factors contributing to people under age 30 seeking ordination in a post-.pdf}
}

