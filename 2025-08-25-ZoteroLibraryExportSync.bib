@article{cueliDifferencesSpanishStudents2022,
  title = {Differences between {{Spanish}} Students' and Teaching Professionals' Knowledge of and Attitudes toward {{ADHD}}—{{Does}} Knowledge Influence Attitude?},
  author = {Cueli, Marisol and Areces, Débora and Rodríguez, Celestino and Cabaleiro, Paloma and González‐Castro, Paloma},
  date = {2022-02},
  journaltitle = {Psychology in the Schools},
  volume = {59},
  number = {2},
