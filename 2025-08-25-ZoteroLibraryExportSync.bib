  urldate = {2017-11-23},
  abstract = {Third, Noll takes note of faculty professionalization in recent decades as large numbers of evangelical Christians attend secular graduate schools and come to Christian colleges with doctorates in hand, professionalized in their disciplinary specialty, as opposed to attending graduate school part-time while teaching in a Christian college, which was more typically the case prior to 1980. Three major developments since 1984 that Ringenberg does not sufficiently consider are the major enhancement of facilities on most college campuses, the improving quality of faculty members as evidenced by graduate degrees, research and writing, and the growth of co-curricular student life programs. Ringenberg, on the other hand, presents detailed descriptions of faculty, finances, students, curriculum, extracurriculum, intercollegiate organizations and church movements though a study of college catalogs and publications, college histories, and articles in scholarly journals, especially those discussing an aspect of the Christian college story},
